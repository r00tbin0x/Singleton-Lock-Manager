#!/bin/bash
# =============================================
# Universal Singleton Lock Manager - Professional Edition
# =============================================

set -euo pipefail

CONFIG_DIR="$HOME/.config"
BACKUP_DIR="$HOME/.config/lock-backups"

# ==================== COLORS ====================
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# ==================== OPTION 2 - UPDATED ====================
check_lock_status() {
    echo
    echo -e "${BLUE}🔍 Scanning for locked profiles across ALL applications...${NC}"
    echo "=========================================="

    local lockfiles=()
    while IFS= read -r -d '' file; do
        lockfiles+=("$file")
    done < <(find "$CONFIG_DIR" -name "SingletonLock" -print0 2>/dev/null | sort -z)

    if [ ${#lockfiles[@]} -eq 0 ]; then
        echo -e "${GREEN}✅ No SingletonLock files found.${NC}"
        echo -e "${GREEN}All profiles are clean.${NC}"
        echo
        read -p "Press Enter to return to menu..." dummy
        return 0
    fi

    echo -e "Found ${#lockfiles[@]} SingletonLock file(s).\n"

    for lockfile in "${lockfiles[@]}"; do
        local profile_dir
        profile_dir=$(dirname "$lockfile")
        echo -e "${BLUE}→ ${profile_dir#$CONFIG_DIR/}${NC}"

        if [ -L "$lockfile" ]; then
            local target
            target=$(readlink "$lockfile" 2>/dev/null || echo "unknown")
            echo "   Symlink → $target"
            
            if [ ! -e "$lockfile" ]; then
                echo -e "${YELLOW}   ⚠️  Broken symlink detected${NC}"
                echo -e "${YELLOW}   (This is normal on Linux while the app is running)${NC}"
            else
                echo -e "${GREEN}   Active symlink${NC}"
            fi
        elif [ ! -s "$lockfile" ]; then
            echo -e "${YELLOW}   ⚠️  Empty lock file${NC}"
        fi

        echo "----------------------------------------"
    done

    echo
    echo -e "${BLUE}=== SUMMARY ===${NC}"
    echo -e "${YELLOW}Broken symlinks are common on Linux with Brave and other Chromium/Electron apps.${NC}"
    echo -e "${YELLOW}They are usually harmless if the app is running normally.${NC}"
    echo
    read -p "Press Enter to return to menu..." dummy
}

show_menu() {
    clear
    echo "=========================================="
    echo "   Singleton Lock Manager - Professional"
    echo "=========================================="
    echo
    echo "1. List all SingletonLock files"
    echo "2. Check lock status (Recommended)"
    echo "3. Kill browser & Electron processes"
    echo "4. Clean ALL SingletonLock files"
    echo "5. Clean specific app"
    echo "6. Backup specific profile"
    echo "7. Restore from backup"
    echo "8. Exit"
    echo
    echo -n "Choose an option (1-8): "
}

# ==================== OTHER FUNCTIONS ====================
list_locks() {
    echo
    echo -e "${BLUE}🔍 Scanning for SingletonLock files...${NC}"
    echo "----------------------------------------"
    find "$CONFIG_DIR" \( -name "SingletonLock" -o -name "SingletonCookie" \) 2>/dev/null | sort | while read -r file; do
        echo "→ $file"
    done
    echo "----------------------------------------"
    read -p "Press Enter to return to menu..." dummy
}

kill_processes() {
    echo
    echo -e "${YELLOW}🛑 Killing browser and Electron processes...${NC}"
    pkill -u "$USER" -f "brave|chrome|chromium|electron" 2>/dev/null || true
    sleep 1.5
    echo -e "${GREEN}✅ Processes terminated.${NC}"
    read -p "Press Enter to return to menu..." dummy
}

clean_all() {
    echo
    echo -e "${RED}⚠️  WARNING: This will kill processes and remove ALL lock files.${NC}"
    read -p "Are you sure? (y/N): " confirm
    if [[ "$confirm" =~ ^[Yy]$ ]]; then
        mkdir -p "$BACKUP_DIR/$(date +%Y%m%d-%H%M%S)"
        local current_backup="$BACKUP_DIR/$(date +%Y%m%d-%H%M%S)"
        
        echo -e "${BLUE}📦 Backing up locks...${NC}"
        find "$CONFIG_DIR" \( -name "SingletonLock" -o -name "SingletonCookie" \) -exec cp --parents {} "$current_backup" \; 2>/dev/null || true
        
        kill_processes
        echo -e "${BLUE}🧹 Removing all lock files...${NC}"
        find "$CONFIG_DIR" \( -name "SingletonLock" -o -name "SingletonCookie" \) -delete 2>/dev/null
        echo -e "${GREEN}✅ All locks cleaned successfully!${NC}"
    else
        echo "Operation cancelled."
    fi
    read -p "Press Enter to return to menu..." dummy
}

clean_specific() {
    echo
    echo -e "${BLUE}Detected apps with lock files:${NC}"
    find "$CONFIG_DIR" \( -name "SingletonLock" -o -name "SingletonCookie" \) 2>/dev/null | \
    sed 's|/SingletonLock$||; s|/SingletonCookie$||' | sort -u | while read -r dir; do
        echo "→ $(basename "$dir")"
    done
    echo
    echo "Enter the app name (e.g. Brave-Browser):"
    read -p "> " appname
    
    if [ -z "$appname" ]; then
        echo "Cancelled."
        read -p "Press Enter to return to menu..." dummy
        return
    fi

    echo -e "${YELLOW}Cleaning locks for $appname...${NC}"
    pkill -u "$USER" -f "$appname" 2>/dev/null || true
    find "$CONFIG_DIR" -path "*/$appname*" \( -name "SingletonLock" -o -name "SingletonCookie" \) -delete 2>/dev/null
    echo -e "${GREEN}✅ Done.${NC}"
    read -p "Press Enter to return to menu..." dummy
}

# Placeholder functions
backup_specific() { 
    echo "Backup feature coming soon..."
    read -p "Press Enter to return to menu..." dummy 
}

restore_from_backup() { 
    echo "Restore feature coming soon..."
    read -p "Press Enter to return to menu..." dummy 
}

# ===================== MAIN LOOP =====================
while true; do
    show_menu
    read -r choice
    
    case $choice in
        1) list_locks ;;
        2) check_lock_status ;;
        3) kill_processes ;;
        4) clean_all ;;
        5) clean_specific ;;
        6) backup_specific ;;
        7) restore_from_backup ;;
        8) echo -e "${GREEN}Goodbye!${NC}"; exit 0 ;;
        *) echo -e "${RED}Invalid option. Please choose 1-8.${NC}"; sleep 1 ;;
    esac
done
